#!/bin/sh
# Keep the intelli-shell command library export in sync with the local database.
# Runs before every commit so the tracked export never drifts from your live rules.
# Only acts when intelli-shell is installed, so committing on a machine without it
# never blocks the commit.

if command -v intelli-shell >/dev/null 2>&1; then
  repo_root=$(git rev-parse --show-toplevel)
  export_file="$repo_root/intelli-shell/commands.bak"
  if intelli-shell export "$export_file" >/dev/null 2>&1; then
    git add "$export_file"
  fi
fi
